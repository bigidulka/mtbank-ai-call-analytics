# Copy to a protected local file; do not commit populated values.
# RunPod public HTTPS proxy base URL. No path, query, fragment, credentials, or private hostname.
MTBANK_RUNPOD_SPEECH_BASE_URL=https://replace-with-runpod-speech.example

# 32+ character high-entropy ASCII secret. Must equal the RunPod container value.
MTBANK_RUNPOD_SPEECH_BEARER_KEY=

# Required in the RunPod Pod environment/secrets UI, never in this file:
# MTBANK_SPEECH__ACCESS__MODE=bearer
# MTBANK_SPEECH__ACCESS__BEARER_KEY=<same secret as MTBANK_RUNPOD_SPEECH_BEARER_KEY>
# MTBANK_SPEECH__RUNTIME__DEVICE=cuda
# MTBANK_SPEECH__MODELS__MANIFEST_PATH=/workspace/models/manifest.json
# MTBANK_SPEECH__MODELS__ARTIFACT_ROOT=/workspace/models/artifacts
# CUDA type remains float16 by typed settings.
